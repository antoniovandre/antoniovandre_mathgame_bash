    "-A") if ! [ "${NUMEROARGUMENTOS}" == "2" ]; then NUMEROARGUMENTOS=$(echo "${NUMEROARGUMENTOS} - 1" | bc); bash antoniovandre_echo_android "${ANOW} ${NUMEROARGUMENTOS}."; else bash antoniovandre_echo_android "${ABOTTOM}"; fi; continue;;
    "+D") if [ "${CASASDECIMAIS}" -lt "${MAXIMOCASASDECIMAIS}" ]; then CASASDECIMAIS=$(echo "${CASASDECIMAIS} + 1" | bc); bash antoniovandre_echo_android "${DNOW} ${CASASDECIMAIS}."; else bash antoniovandre_echo_android "${DOVERFLOW}"; fi; continue;;
    "-D") if ! [ "${CASASDECIMAIS}" == "0" ]; then CASASDECIMAIS=$(echo "${CASASDECIMAIS} - 1" | bc); bash antoniovandre_echo_android "${DNOW} ${CASASDECIMAIS}."; else bash antoniovandre_echo_android "${DBOTTOM}"; fi; continue;;
    "+N") if [ $(echo "${MAXVALUE} * 2" | bc) -lt $MAXMAXVALUE ]; then MAXVALUE=$(echo "${MAXVALUE} * 5" | bc); bash antoniovandre_echo_android "${NNOW} ${MAXVALUE}."; else bash antoniovandre_echo_android "${NOVERFLOW}"; fi; continue;;
