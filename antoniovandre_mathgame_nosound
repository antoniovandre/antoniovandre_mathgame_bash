FLAG="0"

while [  "${RESPOSTAUSUARIO}" != "SAIR" ] && [  "${RESPOSTAUSUARIO}" != "EXIT" ] && [  "${RESPOSTAUSUARIO}" != "sair" ] && [  "${RESPOSTAUSUARIO}" != "exit" ] && [ "${1}" != "oe" ]; do

  if [ "${FLAG}" == "0" ]; then
    SEED=$(date +%s)
    SEED2=$(expr "${SEED}" / 2)
    SEED3=$(expr "${SEED}" / 3)
    SEED4=$(expr "${SEED}" / 4)
    SEED5=$(expr "${SEED}" / 5)
    SEED6=$(expr "${SEED}" / 6)
    SEED7=$(expr "${SEED}" / 7)
    SEED8=$(expr "${SEED}" / 8)
    SEED9=$(expr "${SEED}" / 9)
    SEED10=$(expr "${SEED}" / 10)
    SEED=$(echo "${SEED} % 1000" | bc)
    SEED2=$(echo "${SEED2} % 1000" | bc)
    SEED3=$(echo "${SEED3} % 1000" | bc)
    SEED4=$(echo "${SEED4} % 1000" | bc)
    SEED5=$(echo "${SEED5} % 1000" | bc)
    SEED6=$(echo "${SEED6} % 1000" | bc)
    SEED7=$(echo "${SEED7} % 1000" | bc)
    SEED8=$(echo "${SEED8} % 1000" | bc)
    SEED9=$(echo "${SEED9} % 1000" | bc)
    SEED10=$(echo "${SEED10} % 1000" | bc)

    MAXVALUERED=$(echo "${MAXVALUE} / 4" | bc)

    FATOR=$(echo "10 ^ ${CASASDECIMAIS}" | bc)

    OPS=$(for I in $(seq 1 $(echo "${NUMEROARGUMENTOS} - 1" | bc)); do case $(echo "((${SEED} + ${SEED2} - ${SEED3} + ${SEED4} - ${SEED5} + ${SEED6} - ${SEED7} + ${SEED8} - ${SEED9} + ${SEED10}) + (${I} * ${SEED} * ${SEED2} / ${SEED3} * ${SEED4} * ${SEED5} / ${SEED6} * ${SEED7} * ${SEED8} / ${SEED9} * ${SEED10})) % 4" | bc) in 0) echo -n "+";; 1) echo -n "-";; 2) echo -n "x";; 3) echo -n "/";; *) ;; esac; if [ "${I}" -lt $(echo "${NUMEROARGUMENTOS} - 1" | bc) ]; then echo -n ","; fi; done)

    if [ "${OPS}" != "$(echo -n ${OPS} | tr 'x' ' ')" ] || [ "${OPS}" != "$(echo -n ${OPS} | tr '/' ' ')" ]; then VARVALUE=$MAXVALUERED; else VARVALUE=$MAXVALUE; fi

    PARENTESES=$(if [ "${NUMEROARGUMENTOS}" -gt "2" ]; then TEMP="0"; TEMP2="0"; for I in $(seq 1 "${NUMEROARGUMENTOS}"); do if [ "$TEMP" -lt $(echo  "${NUMEROARGUMENTOS} - ${I}" | bc) ]; then TEMP3=$(echo "(${SEED} * $I) % 3" | bc); case $TEMP3 in 0) echo -n "("; TEMP=$(echo "${TEMP} + 1" | bc);; 1) if [ "$TEMP" -gt "0" ]; then echo -n ")"; TEMP=$(echo "${TEMP} - 1" | bc); fi;; 2) ;; *) ;; esac; else if [ "$TEMP" -gt "0" ]; then if [ $(echo "($SEED+ $TEMP2) % 2" | bc) == "0" ]; then echo -n ")"; TEMP=$(echo "${TEMP} - 1" | bc); else TEMP2="1"; fi; fi; fi; if [ "${I}" -lt "${NUMEROARGUMENTOS}" ]; then echo -n ","; fi; done; fi)

    ARGS=$(for I in $(seq 1 "${NUMEROARGUMENTOS}"); do TEMP=$(awk "BEGIN{print ((${SEED} + ${SEED2} + ${SEED3} + ${SEED4} - ${SEED5} + ${SEED6} + ${SEED7} + ${SEED8} - ${SEED9} + ${SEED10}) + ${I} * ${SEED} * ${SEED2} * ${SEED3} * ${SEED4} / ${SEED5} * ${SEED6} * ${SEED7} * ${SEED8} * ${SEED9} / ${SEED10}) / ${FATOR}}"); awk "BEGIN{print ${TEMP} % ${VARVALUE}}" | tr "\n" ","; done)

    QUESTAO="$(for I in $(seq 1 "${NUMEROARGUMENTOS}"); do TEMP=$(echo -n "${PARENTESES}" | cut -d "," -f "${I}"); if [ "${TEMP}" == "(" ]; then echo -n "${TEMP}"; fi; if [ "${TEMP}" == ")" ]; then echo -n "${ARGS}" | cut -d "," -f "${I}" | tr -d "\n"; else echo -n "${ARGS}" | cut -d "," -f "${I}"; fi; if [ "${TEMP}" == ")" ]; then echo -n "${TEMP}"; fi; if [ "${I}" -lt "${NUMEROARGUMENTOS}" ]; then if [ "${TEMP}" == ")" ]; then echo -n " "; fi; echo -n "${OPS}" | cut -d "," -f "${I}"; fi; done)"

    rm "$ARQUIVOTEMP" &>> /dev/null

    TEMP=$(echo $QUESTAO | tr "x" "*" | bc -l 2>> "${ARQUIVOTEMP}")

    if [ "$(wc -c ${ARQUIVOTEMP} | cut -d ' ' -f 1)" -gt "0" ]; then sleep 1s; continue; else RESPOSTABRUTA=$TEMP; fi

    TEMP=$(LC_NUMERIC="en_US.UTF-8" printf "%.${CASASDECIMAIS}f" "${RESPOSTABRUTA}")

    TEMP2=$(echo "${TEMP} * ${FATOR}" | bc)

    RESPOSTATEMP1=${TEMP2%.*}

    RESPOSTATEMP2=$(awk "BEGIN{print ${RESPOSTABRUTA} * ${FATOR}}")

    if ! [ "${RESPOSTATEMP1}" == "${RESPOSTATEMP2}" ]; then if ! [ "${CASASDECIMAIS}" == "1" ]; then QUESTAODECIMAL=", ${ROUNDWITH} ${CASASDECIMAIS} ${DECIMALPLACES}"; else QUESTAODECIMAL=", ${ROUNDWITH} 1 ${DECIMALPLACE}"; fi; else QUESTAODECIMAL=""; fi

    RESPOSTA=$(LC_NUMERIC="en_US.UTF-8" printf "%.${CASASDECIMAIS}f" "$(echo ${QUESTAO} | tr 'x' '*' | bc -l)")

    RESPOSTA=$(awk "BEGIN{print ${RESPOSTA}}")

    PERGUNTA=$(echo "${HOWMUCH} ${QUESTAO}${QUESTAODECIMAL}?" | tr "\n" " ")
  fi

  bash antoniovandre_echo_android_nosound "${PERGUNTA}"

  if [ "${AVTEMPO}" == "1" ]; then if ! read -t $LIMITETEMPO RESPOSTAUSUARIO &>> /dev/null; then echo "${TIMELIMITOF} ${LIMITETEMPO} ${SECONDSREACHED}."; continue; fi; else read RESPOSTAUSUARIO; fi

  RESPOSTAUSUARIOP=$RESPOSTAUSUARIO

  if ! ([ "${RESPOSTAUSUARIO}" == "+A" ] || [ "${RESPOSTAUSUARIO}" == "-A" ] || [ "${RESPOSTAUSUARIO}" == "+D" ] || [ "${RESPOSTAUSUARIO}" == "-D" ] || [ "${RESPOSTAUSUARIO}" == "+N" ] || [ "${RESPOSTAUSUARIO}" == "-N" ] || [ "${RESPOSTAUSUARIO}" == "T" ] || [ "${RESPOSTAUSUARIO}" == "t" ] || [ "${RESPOSTAUSUARIO}" == "+T" ] || [ "${RESPOSTAUSUARIO}" == "-T" ] || [ "${RESPOSTAUSUARIO}" == "SAIR" ] || [ "${RESPOSTAUSUARIO}" == "EXIT" ] || [ "${RESPOSTAUSUARIO}" == "sair" ] || [ "${RESPOSTAUSUARIO}" == "exit" ] || [ "${RESPOSTAUSUARIO}" == "PULAR" ] || [ "${RESPOSTAUSUARIO}" == "JUMP" ] || [ "${RESPOSTAUSUARIO}" == "pular" ] || [ "${RESPOSTAUSUARIO}" == "jump" ] || [ "${RESPOSTAUSUARIO}" == "M" ]); then RESPOSTAUSUARIO=$(echo "${RESPOSTAUSUARIO}" | tr -d "\"" | tr -d "'" | tr -d "\`" | tr -d "\$" | tr "x" "*" | tr "X" "*" | tr -d " "); RESPOSTAUSUARIO=$(LC_NUMERIC="en_US.UTF-8" printf "%.${CASASDECIMAIS}f" "$(echo ${RESPOSTAUSUARIO} | bc -l 2>> /dev/null)"); RESPOSTAUSUARIO=$(awk "BEGIN{print ${RESPOSTAUSUARIO}}"); fi

  case "${RESPOSTAUSUARIO}" in
    "+A") if [ "${NUMEROARGUMENTOS}" -lt "${NUMEROMAXIMOARGUMENTOS}" ]; then NUMEROARGUMENTOS=$(echo "${NUMEROARGUMENTOS} + 1" | bc); bash antoniovandre_echo_android_nosound "${ANOW} ${NUMEROARGUMENTOS}."; else bash antoniovandre_echo_android_nosound "${AOVERFLOW}"; fi; FLAG="0"; continue;;
    "-A") if ! [ "${NUMEROARGUMENTOS}" == "2" ]; then NUMEROARGUMENTOS=$(echo "${NUMEROARGUMENTOS} - 1" | bc); bash antoniovandre_echo_android_nosound "${ANOW} ${NUMEROARGUMENTOS}."; else bash antoniovandre_echo_android_nosound "${ABOTTOM}"; fi; FLAG="0"; continue;;
    "+D") if [ "${CASASDECIMAIS}" -lt "${MAXIMOCASASDECIMAIS}" ]; then CASASDECIMAIS=$(echo "${CASASDECIMAIS} + 1" | bc); bash antoniovandre_echo_android_nosound "${DNOW} ${CASASDECIMAIS}."; else bash antoniovandre_echo_android_nosound "${DOVERFLOW}"; fi; FLAG="0"; continue;;
    "-D") if ! [ "${CASASDECIMAIS}" == "0" ]; then CASASDECIMAIS=$(echo "${CASASDECIMAIS} - 1" | bc); bash antoniovandre_echo_android_nosound "${DNOW} ${CASASDECIMAIS}."; else bash antoniovandre_echo_android_nosound "${DBOTTOM}"; fi; FLAG="0"; continue;;
    "+N") if [ $(echo "${MAXVALUE} * 2" | bc) -lt $MAXMAXVALUE ]; then MAXVALUE=$(echo "${MAXVALUE} * 5" | bc); bash antoniovandre_echo_android_nosound "${NNOW} ${MAXVALUE}."; else bash antoniovandre_echo_android_nosound "${NOVERFLOW}"; fi; FLAG="0"; continue;;
    "-N") if [ "${MAXVALUE}" -gt "${MINMAXVALUE}" ]; then MAXVALUE=$(echo "${MAXVALUE} / 2" | bc); bash antoniovandre_echo_android_nosound "${NNOW} ${MAXVALUE}."; else bash antoniovandre_echo_android_nosound "${NBOTTOM}"; fi; FLAG="0"; continue;;
    "T") if [ "${AVTEMPO}" == "0" ]; then AVTEMPO="1"; bash antoniovandre_echo_android_nosound "${TNOW} ${AVTEMPO}."; else bash antoniovandre_echo_android_nosound "${TIMEALREADYACTIVATED}"; fi; FLAG="1"; continue;;
