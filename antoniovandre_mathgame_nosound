    "+T") if [ "${AVTEMPO}" == "1" ]; then if [ "${LIMITETEMPO}" -lt "${MAXTIME}" ]; then LIMITETEMPO=$(echo "${LIMITETEMPO} + 10" | bc); bash antoniovandre_echo_android_nosound "${TVNOW} ${LIMITETEMPO}."; else bash antoniovandre_echo_android_nosound "${TOVERFLOW}"; fi; else bash antoniovandre_echo_android_nosound "${TIMEDEACTIVATED}"; fi; FLAG="1"; continue;;
